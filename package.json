{
    "name": "arkimedia-theme",
    "version": "1.0.0",
    "description": "Arkimedia WordPress Theme",
    "scripts": {
        "build:hero": "wp-scripts build blocks/hero/index.js --output-path=blocks/hero/build",
        "build:services": "wp-scripts build blocks/services/index.js --output-path=blocks/services/build",
        "build:clients": "wp-scripts build blocks/clients/index.js --output-path=blocks/clients/build",
        "build:gallery-cta": "wp-scripts build blocks/gallery-cta/index.js --output-path=blocks/gallery-cta/build",
        "build:slider": "wp-scripts build blocks/slider/index.js --output-path=blocks/slider/build",
        "build:container": "wp-scripts build blocks/container/index.js --output-path=blocks/container/build",
        "build:contact": "wp-scripts build blocks/contact/index.js --output-path=blocks/contact/build",
        "build:testata": "wp-scripts build blocks/testata/index.js --output-path=blocks/testata/build",
        "build:map": "wp-scripts build blocks/map/index.js --output-path=blocks/map/build",
        "build:gallery": "wp-scripts build blocks/gallery/index.js --output-path=blocks/gallery/build",
        "build:portfolio-meta": "wp-scripts build blocks/portfolio-meta/index.js --output-path=blocks/portfolio-meta/build",
        "build:ark-text": "wp-scripts build blocks/ark-text/index.js --output-path=blocks/ark-text/build",
        "build:ark-image": "wp-scripts build blocks/ark-image/index.js --output-path=blocks/ark-image/build",
        "build:row": "wp-scripts build blocks/row/index.js --output-path=blocks/row/build",
        "build": "npm run build:hero && npm run build:services && npm run build:clients && npm run build:gallery-cta && npm run build:slider && npm run build:container && npm run build:contact && npm run build:testata && npm run build:map && npm run build:gallery && npm run build:portfolio-meta && npm run build:ark-text && npm run build:ark-image && npm run build:row",
        "start:row": "wp-scripts start blocks/row/index.js --output-path=blocks/row/build"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.0.0"
    }
}