{
    "apiVersion": 3,
    "name": "arkimedia/testata",
    "title": "Testata",
    "description": "Testata pagina interna con immagine, titolo automatico e header sticky trasparente.",
    "category": "arkimedia",
    "icon": "cover-image",
    "supports": { "html": false, "align": ["full"] },
    "attributes": {
        "align":          { "type": "string",  "default": "full" },
        "usePageTitle":   { "type": "boolean", "default": true },
        "customTitle":    { "type": "string",  "default": "" },
        "showTitle":      { "type": "boolean", "default": true },
        "eyebrow":        { "type": "string",  "default": "" },
        "height":         { "type": "string",  "default": "70vh" },
        "bgType":         { "type": "string",  "default": "image" },
        "mediaUrl":       { "type": "string",  "default": "" },
        "mediaAlt":       { "type": "string",  "default": "" },
        "bgColor":        { "type": "string",  "default": "#1a1a2e" },
        "gradientType":   { "type": "string",  "default": "linear" },
        "gradientAngle":  { "type": "number",  "default": 135 },
        "gradientColor1": { "type": "string",  "default": "#1a1a2e" },
        "gradientColor2": { "type": "string",  "default": "#e94560" },
        "overlayColor":   { "type": "string",  "default": "rgba(0,0,0,0.45)" },
        "bgSize":         { "type": "string",  "default": "cover" },
        "bgPosition":     { "type": "string",  "default": "center center" },
        "bgAttachment":   { "type": "string",  "default": "scroll" },
        "textColor":      { "type": "string",  "default": "#ffffff" },
        "titleSize":      { "type": "string",  "default": "clamp(2.5rem,5vw,5rem)" },
        "contentPosition":{ "type": "string",  "default": "bottom" }
    },
    "render": "file:./render.php",
    "editorScript": "file:./build/index.js",
    "style": "file:./style.css"
}
