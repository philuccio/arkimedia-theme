{
    "apiVersion": 3,
    "name": "arkimedia/image",
    "title": "Immagine",
    "description": "Blocco immagine completamente configurabile.",
    "category": "arkimedia",
    "icon": "format-image",
    "supports": { "html": false },
    "attributes": {
        "mediaUrl":     { "type": "string",  "default": "" },
        "mediaAlt":     { "type": "string",  "default": "" },
        "mediaId":      { "type": "number",  "default": 0 },
        "caption":      { "type": "string",  "default": "" },
        "linkUrl":      { "type": "string",  "default": "" },
        "linkTarget":   { "type": "string",  "default": "_self" },
        "lightbox":     { "type": "boolean", "default": false },
        "width":        { "type": "string",  "default": "100%" },
        "height":       { "type": "string",  "default": "auto" },
        "objectFit":    { "type": "string",  "default": "cover" },
        "objectPosition":{ "type": "string", "default": "center center" },
        "borderRadius": { "type": "number",  "default": 0 },
        "align":        { "type": "string",  "default": "none" },
        "hoverEffect":  { "type": "string",  "default": "none" },
        "opacity":      { "type": "number",  "default": 1 },
        "paddingTop":   { "type": "number",  "default": 0 },
        "paddingBottom":{ "type": "number",  "default": 0 },
        "marginTop":    { "type": "number",  "default": 0 },
        "marginBottom": { "type": "number",  "default": 0 },
        "maxWidth":     { "type": "string",  "default": "" },
        "aspectRatio":  { "type": "string",  "default": "" },
        "filter":       { "type": "string",  "default": "none" }
    },
    "render": "file:./render.php",
    "editorScript": "file:./build/index.js",
    "style": "file:./style.css"
}
