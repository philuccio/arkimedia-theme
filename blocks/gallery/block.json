{
    "apiVersion": 3,
    "name": "arkimedia/gallery",
    "title": "Gallery Servizio",
    "description": "Gallery fotografica con layout griglia, masonry o bento. Supporta cartelle Virtual Media Folders o selezione manuale.",
    "category": "arkimedia",
    "icon": "format-gallery",
    "supports": { "html": false, "align": ["full", "wide"] },
    "attributes": {
        "align":       { "type": "string",  "default": "full" },
        "useFolder":   { "type": "boolean", "default": false },
        "folderId":    { "type": "number",  "default": 0 },
        "folderName":  { "type": "string",  "default": "" },
        "images": {
            "type": "array",
            "default": []
        },
        "layout":      { "type": "string",  "default": "grid" },
        "columns":     { "type": "number",  "default": 3 },
        "gap":         { "type": "number",  "default": 8 },
        "aspectRatio": { "type": "string",  "default": "4/3" },
        "lightbox":    { "type": "boolean", "default": true },
        "bgColor":     { "type": "string",  "default": "" },
        "paddingTop":  { "type": "number",  "default": 0 },
        "paddingBottom":{ "type": "number", "default": 0 }
    },
    "render": "file:./render.php",
    "editorScript": "file:./build/index.js",
    "style": "file:./style.css"
}
