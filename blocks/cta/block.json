{
    "apiVersion": 3,
    "name": "arkimedia/cta",
    "title": "CTA",
    "description": "Sezione chiamata all'azione con 3 layout configurabili.",
    "category": "arkimedia",
    "icon": "megaphone",
    "supports": { "html": false, "align": ["full"] },
    "attributes": {
        "align":          { "type": "string",  "default": "full" },
        "layout":         { "type": "string",  "default": "A" },
        "eyebrow":        { "type": "string",  "default": "" },
        "eyebrowColor":   { "type": "string",  "default": "" },
        "title":          { "type": "string",  "default": "" },
        "titleColor":     { "type": "string",  "default": "#ffffff" },
        "titleSize":      { "type": "string",  "default": "clamp(2rem,5vw,3.5rem)" },
        "titleWeight":    { "type": "string",  "default": "700" },
        "titleLineHeight":{ "type": "string",  "default": "1.1" },
        "description":    { "type": "string",  "default": "" },
        "descColor":      { "type": "string",  "default": "rgba(255,255,255,0.75)" },
        "descSize":       { "type": "string",  "default": "1rem" },
        "cta1Label":      { "type": "string",  "default": "" },
        "cta1Url":        { "type": "string",  "default": "#" },
        "cta1Style":      { "type": "string",  "default": "filled" },
        "cta1BgColor":    { "type": "string",  "default": "" },
        "cta1TextColor":  { "type": "string",  "default": "#ffffff" },
        "cta2Label":      { "type": "string",  "default": "" },
        "cta2Url":        { "type": "string",  "default": "#" },
        "cta2Style":      { "type": "string",  "default": "outline" },
        "cta2BgColor":    { "type": "string",  "default": "" },
        "cta2TextColor":  { "type": "string",  "default": "#ffffff" },
        "bgType":         { "type": "string",  "default": "color" },
        "bgColor":        { "type": "string",  "default": "#1a1a2e" },
        "gradientAngle":  { "type": "number",  "default": 135 },
        "gradientColor1": { "type": "string",  "default": "#1a1a2e" },
        "gradientColor2": { "type": "string",  "default": "#e94560" },
        "bgImageUrl":     { "type": "string",  "default": "" },
        "bgImageAlt":     { "type": "string",  "default": "" },
        "bgImageId":      { "type": "number",  "default": 0 },
        "bgSize":         { "type": "string",  "default": "cover" },
        "bgPosition":     { "type": "string",  "default": "center center" },
        "overlayColor":   { "type": "string",  "default": "rgba(0,0,0,0.5)" },
        "minHeight":      { "type": "string",  "default": "400px" },
        "isFullwidth":    { "type": "boolean", "default": true },
        "textAlign":      { "type": "string",  "default": "center" },
        "borderRadius":   { "type": "number",  "default": 0 },
        "boxShadow":      { "type": "boolean", "default": false },
        "shadowColor":    { "type": "string",  "default": "rgba(0,0,0,0.3)" },
        "shadowBlur":     { "type": "number",  "default": 30 },
        "paddingTop":     { "type": "number",  "default": 80 },
        "paddingBottom":  { "type": "number",  "default": 80 },
        "paddingLeft":    { "type": "number",  "default": 0 },
        "paddingRight":   { "type": "number",  "default": 0 },
        "marginTop":      { "type": "number",  "default": 0 },
        "marginBottom":   { "type": "number",  "default": 0 },
        "animationType":  { "type": "string",  "default": "none" },
        "animationDelay": { "type": "number",  "default": 0 }
    },
    "render": "file:./render.php",
    "editorScript": "file:./build/index.js",
    "style": "file:./style.css"
}
