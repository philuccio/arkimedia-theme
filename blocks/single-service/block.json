{
    "apiVersion": 3,
    "name": "arkimedia/single-service",
    "title": "Single Service",
    "description": "Sezione servizio fullwidth con immagine 1/3 e testo 2/3.",
    "category": "arkimedia",
    "icon": "align-pull-left",
    "supports": { "html": false, "align": ["full"] },
    "attributes": {
        "align":           { "type": "string",  "default": "full" },
        "imageUrl":        { "type": "string",  "default": "" },
        "imageAlt":        { "type": "string",  "default": "" },
        "imageId":         { "type": "number",  "default": 0 },
        "imagePosition":   { "type": "string",  "default": "left" },
        "objectFit":       { "type": "string",  "default": "cover" },
        "objectPosition":  { "type": "string",  "default": "center center" },
        "imageFlex":       { "type": "string",  "default": "1" },
        "textFlex":        { "type": "string",  "default": "2" },
        "title":           { "type": "string",  "default": "" },
        "titleColor":      { "type": "string",  "default": "#ffffff" },
        "titleSize":       { "type": "string",  "default": "clamp(2rem,5vw,3.5rem)" },
        "titleWeight":     { "type": "string",  "default": "700" },
        "titleLineHeight": { "type": "string",  "default": "1.1" },
        "description":     { "type": "string",  "default": "" },
        "descColor":       { "type": "string",  "default": "rgba(255,255,255,0.75)" },
        "descSize":        { "type": "string",  "default": "1rem" },
        "ctaLabel":        { "type": "string",  "default": "" },
        "ctaUrl":          { "type": "string",  "default": "#" },
        "ctaBgColor":      { "type": "string",  "default": "" },
        "ctaTextColor":    { "type": "string",  "default": "#ffffff" },
        "ctaBorderColor":  { "type": "string",  "default": "" },
        "ctaStyle":        { "type": "string",  "default": "filled" },
        "minHeight":       { "type": "string",  "default": "500px" },
        "alignItems":      { "type": "string",  "default": "center" },
        "gap":             { "type": "number",  "default": 0 },
        "bgColor":         { "type": "string",  "default": "#0a0a0a" },
        "textPaddingTop":    { "type": "number", "default": 60 },
        "textPaddingBottom": { "type": "number", "default": 60 },
        "textPaddingLeft":   { "type": "number", "default": 60 },
        "textPaddingRight":  { "type": "number", "default": 60 },
        "borderRadius":    { "type": "number",  "default": 0 },
        "boxShadow":       { "type": "boolean", "default": false },
        "shadowColor":     { "type": "string",  "default": "rgba(0,0,0,0.3)" },
        "shadowBlur":      { "type": "number",  "default": 30 },
        "shadowSpread":    { "type": "number",  "default": 0 },
        "animationType":   { "type": "string",  "default": "none" }
    },
    "render": "file:./render.php",
    "editorScript": "file:./build/index.js",
    "style": "file:./style.css"
}
